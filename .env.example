# -----------------------------------------------------------------------------
# Frontend (this Nuxt app)
# -----------------------------------------------------------------------------
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Python backend — proxied via /api/** (users never visit this URL directly)
NUXT_PUBLIC_API_BASE=https://api.ytshort.site

# Local dev: point at your local FastAPI server instead
# NUXT_PUBLIC_API_BASE=http://localhost:8000

# -----------------------------------------------------------------------------
# Ranking limits (optional overrides)
# -----------------------------------------------------------------------------
# MAX_RANKING_ITEMS=10
# MAX_UPLOAD_MB=100
# MAX_CLIP_DURATION_SECONDS=60
